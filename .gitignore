# 隱藏所有環境變數檔案 (包含 API Key)
.env
*.env

# 隱藏 Python 虛擬環境與快取
.venv/
__pycache__/
*.py[cod]

# 隱藏資料庫 (保護交易紀錄)
*.db
*.sqlite3

# 隱藏日誌與系統垃圾
*.log
.DS_Store

# 隱藏個人開發筆記 (選用，若想保持專案乾淨)
*.txt
!README.md
!requirements.txt

# =========================
# 以下為新增的防護與 AI 忽略規則
# =========================

# 其他常見的 Python 虛擬環境名稱
venv/
ENV/
env/

# 進階資安防護 (防止交易金鑰或憑證外流)
*.pem
secrets.json
.env.*

# AI Agent 與 CLI 專用暫存 (防止 Gemini 讀取過慢)
.gemini_audit.log
.cline/
.cursor/

# IDE 開發工具設定檔 (避免上傳個人編輯器環境)
.vscode/
.idea/